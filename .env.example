# 复制为 .env 后，二选一配置官方 DeepSeek 或 ModelScope；不要在此文件写真实密钥。

# 官方 DeepSeek（默认）
AI_API_KEY=your_api_key_here
AI_API_BASE=https://api.deepseek.com
AI_THINKING_ENABLED=true
AI_SLIDE_PLANNER_ENABLED=true

# 课程知识规划共享并发预算：默认 4，代码会限制在 1-8 之间。
# 提供方出现 429 或延迟抖动时优先下调，不要靠降低模型质量换速度。
COURSE_GENERATION_PLANNING_CONCURRENCY=4

# 全课教案采用“全局骨架 → 有界批次 → 本地汇编”。auto 仅对不超过 3 节且预算安全的
# 小课使用紧凑单次调用；大课默认每批最多 3 节/15 个知识点，并发 2。
COURSE_TEACHING_PLAN_MODE=auto
COURSE_TEACHING_PLAN_COMPACT_MAX_SECTIONS=3
COURSE_TEACHING_PLAN_BATCH_MAX_SECTIONS=3
COURSE_TEACHING_PLAN_BATCH_MAX_KNOWLEDGE=15
COURSE_TEACHING_PLAN_MAX_INPUT_TOKENS=8000
COURSE_TEACHING_PLAN_MAX_OUTPUT_TOKENS=10000
COURSE_TEACHING_PLAN_CONCURRENCY=2
COURSE_TEACHING_PLAN_BATCH_TIMEOUT_SECONDS=300

# 本地默认只写文件，不让运行数据自动产生 Git 提交。
# 只有明确需要由部署环境托管数据版本时才改为 true。
GIT_AUTO_SYNC_ENABLED=false

# 官方 DeepSeek 会自动默认 deepseek-v4-pro / deepseek-v4-flash。
# 如需固定模型，可取消以下两行注释：
# AI_MODEL=deepseek-v4-pro
# AI_MODEL_FAST=deepseek-v4-flash

# 或者改为 ModelScope：
# AI_API_KEY=your_modelscope_api_key_here
# AI_API_BASE=https://api-inference.modelscope.cn/v1
# AI_MODEL_CANDIDATES=Qwen/Qwen3.5-27B,Qwen/Qwen3.5-122B-A10B,Qwen/Qwen3.5-397B-A17B
# AI_MODEL_FAST_CANDIDATES=Qwen/Qwen3.5-27B,Qwen/Qwen3.5-122B-A10B,Qwen/Qwen3.5-397B-A17B
