# 复制为 .env 后，二选一配置官方 DeepSeek 或 ModelScope；不要在此文件写真实密钥。

# 官方 DeepSeek（默认）
AI_API_KEY=your_api_key_here
AI_API_BASE=https://api.deepseek.com
AI_THINKING_ENABLED=true
AI_MIN_REQUEST_INTERVAL_SECONDS=1.5
QUESTION_BANK_REBUILD_MAX_WORKERS=1
ASSESSMENT_SLOT_CONCURRENCY=1
ASSESSMENT_GENERATION_BATCH_SIZE=2
ASSESSMENT_SEMANTIC_BATCH_WAIT_SECONDS=12
# 同一学习目标内的跨题型语义判重阈值，代码强制限制在 0.50-0.95。
ASSESSMENT_DIVERSITY_THRESHOLD=0.72
# 可按学科覆盖全局值：STEM、PROGRAMMING、LANGUAGE、HUMANITIES、GENERAL。
# ASSESSMENT_DIVERSITY_THRESHOLD_STEM=0.72
# ASSESSMENT_DIVERSITY_THRESHOLD_PROGRAMMING=0.72
AI_SLIDE_PLANNER_ENABLED=true

# 课程知识规划共享并发预算：默认 4，代码会限制在 1-8 之间。
# 提供方出现 429 或延迟抖动时优先下调，不要靠降低模型质量换速度。
COURSE_GENERATION_PLANNING_CONCURRENCY=4

# 首次课程生成不限制课程总章节数。以下配置只限制单次请求或一次可恢复工作窗口；
# 大课会继续拆分、并行、保存检查点，而不是拒绝用户或发送超大载荷。
COURSE_GENERATION_MAX_INPUT_CHARS=20000
COURSE_GENERATION_MAX_INPUT_TOKENS=7000
COURSE_OUTLINE_MAX_OUTPUT_TOKENS=4096
COURSE_CONTENT_MAX_OUTPUT_TOKENS=8192
COURSE_GENERATION_PROVIDER_MAX_ATTEMPTS=2
COURSE_GENERATION_CALL_TIMEOUT_SECONDS=90
COURSE_CONTENT_NODE_TIMEOUT_SECONDS=75
COURSE_CONTENT_STAGE_TIMEOUT_SECONDS=480
COURSE_CONTENT_CONCURRENCY=4
COURSE_CONTENT_MAX_RETRIES=1

# 目录采用“小课紧凑调用 / 大课章节骨架 → 按章并行小节批次 → 本地汇编”。
# 每批最多 6 节只是单次调用颗粒度，不是课程总量上限。章节之间并行，同一章的多个
# 批次按顺序生成；180 秒工作窗口到期后只本地补齐未完成批次并进入目录人工审阅。
COURSE_OUTLINE_COMPACT_MAX_SECTIONS=6
COURSE_OUTLINE_BATCH_MAX_SECTIONS=6
COURSE_OUTLINE_BATCH_TIMEOUT_SECONDS=60
COURSE_OUTLINE_TOTAL_TIMEOUT_SECONDS=180

# 全课教案采用“有界骨架分片 → 有界详细批次 → 本地汇编”。auto 仅对不超过 3 节且
# 预算安全的小课使用紧凑单次调用；大课骨架每片最多 6 节，详细批次最多 3 节/
# 15 个知识点，并发 4。单片仍超预算或提供方失败时，只本地编译该最小单元。
COURSE_TEACHING_PLAN_MODE=auto
COURSE_TEACHING_PLAN_COMPACT_MAX_SECTIONS=3
COURSE_TEACHING_PLAN_SKELETON_MAX_SECTIONS=6
COURSE_TEACHING_PLAN_BATCH_MAX_SECTIONS=3
COURSE_TEACHING_PLAN_BATCH_MAX_KNOWLEDGE=15
COURSE_TEACHING_PLAN_MAX_INPUT_TOKENS=7000
COURSE_TEACHING_PLAN_MAX_OUTPUT_TOKENS=8000
COURSE_TEACHING_PLAN_CONCURRENCY=4
COURSE_TEACHING_PLAN_BATCH_TIMEOUT_SECONDS=60
COURSE_TEACHING_PLAN_TOTAL_TIMEOUT_SECONDS=360

# 本地默认只写文件，不让运行数据自动产生 Git 提交。
# 只有明确需要由部署环境托管数据版本时才改为 true。
GIT_AUTO_SYNC_ENABLED=false

# 官方 DeepSeek 会自动默认 deepseek-v4-pro / deepseek-v4-flash。
# 如需固定模型，可取消以下两行注释：
# AI_MODEL=deepseek-v4-pro
# AI_MODEL_FAST=deepseek-v4-flash

# 或者改为 ModelScope：
# AI_API_KEY=your_modelscope_api_key_here
# AI_API_BASE=https://api-inference.modelscope.cn/v1
# AI_MODEL_CANDIDATES=Qwen/Qwen3.5-122B-A10B,Qwen/Qwen3.5-397B-A17B,deepseek-ai/DeepSeek-V4-Flash
# AI_MODEL_FAST_CANDIDATES=deepseek-ai/DeepSeek-V4-Flash,Qwen/Qwen3.5-122B-A10B,Qwen/Qwen3.5-397B-A17B
# 可选：为出题、独立求解和质量评审配置不同模型池。
# 未配置时，求解器会从通用候选池的第二个模型开始，降低同模型自审。
# AI_ASSESSMENT_GENERATOR_MODELS=Qwen/Qwen3.5-122B-A10B,Qwen/Qwen3.5-397B-A17B,deepseek-ai/DeepSeek-V4-Flash
# AI_ASSESSMENT_SOLVER_MODELS=Qwen/Qwen3.5-397B-A17B,Qwen/Qwen3.5-122B-A10B,deepseek-ai/DeepSeek-V4-Flash
# AI_ASSESSMENT_REVIEWER_MODELS=deepseek-ai/DeepSeek-V4-Flash,Qwen/Qwen3.5-397B-A17B,Qwen/Qwen3.5-122B-A10B

# 可选联网题型参考；没有密钥时安全回退到教师题库和课程材料。
# EXA_API_KEY=your_exa_api_key_here

# 正式代码题必须连接独立 Runner；未配置时代码实现题不会自动投放。
FORMAL_RUNNER_URL=http://formal-runner:8091
FORMAL_RUNNER_TOKEN=replace_with_a_long_random_internal_token
# Linux 主机上 Docker socket 所属组 ID，可用 `stat -c %g /var/run/docker.sock` 查看。
DOCKER_GID=999
