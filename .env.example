# 复制为 .env 后，二选一配置官方 DeepSeek 或 ModelScope；不要在此文件写真实密钥。

# 官方 DeepSeek（默认）
AI_API_KEY=your_api_key_here
AI_API_BASE=https://api.deepseek.com
AI_THINKING_ENABLED=true
AI_MIN_REQUEST_INTERVAL_SECONDS=1.5
ASSESSMENT_SLOT_CONCURRENCY=2
ASSESSMENT_GENERATION_BATCH_SIZE=2
ASSESSMENT_SEMANTIC_BATCH_WAIT_SECONDS=12
AI_SLIDE_PLANNER_ENABLED=true

# 课程知识规划共享并发预算：默认 4，代码会限制在 1-8 之间。
# 提供方出现 429 或延迟抖动时优先下调，不要靠降低模型质量换速度。
COURSE_GENERATION_PLANNING_CONCURRENCY=4

# 官方 DeepSeek 会自动默认 deepseek-v4-pro / deepseek-v4-flash。
# 如需固定模型，可取消以下两行注释：
# AI_MODEL=deepseek-v4-pro
# AI_MODEL_FAST=deepseek-v4-flash

# 或者改为 ModelScope：
# AI_API_KEY=your_modelscope_api_key_here
# AI_API_BASE=https://api-inference.modelscope.cn/v1
# AI_MODEL_CANDIDATES=deepseek-ai/DeepSeek-V4-Pro,deepseek-ai/DeepSeek-V4-Flash
# AI_MODEL_FAST_CANDIDATES=deepseek-ai/DeepSeek-V4-Flash
# 可选：为出题、独立求解和质量评审配置不同模型池。
# 未配置时，求解器会从通用候选池的第二个模型开始，降低同模型自审。
# AI_ASSESSMENT_GENERATOR_MODELS=generator-model-a,generator-model-b
# AI_ASSESSMENT_SOLVER_MODELS=solver-model-a,solver-model-b
# AI_ASSESSMENT_REVIEWER_MODELS=reviewer-model-a,reviewer-model-b

# 可选联网题型参考；没有密钥时安全回退到教师题库和课程材料。
# EXA_API_KEY=your_exa_api_key_here

# 正式代码题必须连接独立 Runner；未配置时代码实现题不会自动投放。
FORMAL_RUNNER_URL=http://formal-runner:8091
FORMAL_RUNNER_TOKEN=replace_with_a_long_random_internal_token
# Linux 主机上 Docker socket 所属组 ID，可用 `stat -c %g /var/run/docker.sock` 查看。
DOCKER_GID=999
